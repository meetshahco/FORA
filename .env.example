# FORA — Environment Variables
# Copy this file to .env and fill in your values

# Required for codegen
ANTHROPIC_API_KEY=

# Required for deployment
VERCEL_TOKEN=
VERCEL_PROJECT_NAME=

# Optional — deployment target domain
DEPLOY_DOMAIN=

# Optional — analytics
POSTHOG_API_KEY=

# AI model (default: claude-sonnet-4-5)
AI_MODEL=claude-sonnet-4-5
